# ============================================================
# BizCore — Variables de entorno (PLANTILLA)
# ============================================================
# INSTRUCCIONES:
# 1. Copia este archivo: cp .env.example .env
# 2. Llena los valores reales en .env
# 3. NUNCA subas .env a GitHub (ya está en .gitignore)
# 4. Sí sube .env.example — es la plantilla para otros desarrolladores
#
# POR QUÉ variables de entorno y no hardcodear en el código?
# Dos razones principales:
# a) Seguridad: las contraseñas no quedan en el historial de git
# b) Portabilidad: el mismo código funciona en dev, staging y prod
#    cambiando solo este archivo, sin tocar el código fuente
# ============================================================

# --- Base de datos ---
# Formato: postgresql+asyncpg://usuario:contraseña@host:puerto/nombre_bd
# - postgresql+asyncpg: usa asyncpg como driver (más rápido, async nativo)
# - postgres: el superusuario de PostgreSQL que configuramos al instalar
# - localhost: la BD corre en la misma máquina
# - 5432: el puerto por defecto de PostgreSQL
# - bizcore: el nombre de la base de datos que vamos a crear
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/bizcore

# --- Seguridad JWT ---
# SECRET_KEY: una clave secreta larga y aleatoria para firmar los tokens.
# NUNCA uses esta clave en producción. Genera una nueva con:
# python -c "import secrets; print(secrets.token_hex(32))"
#
# ALGORITHM: el algoritmo de firma. HS256 (HMAC-SHA256) es el estándar.
# ACCESS_TOKEN_EXPIRE_MINUTES: cuánto tiempo dura un access token.
# 15 minutos es el estándar de seguridad recomendado.
SECRET_KEY=CAMBIA_ESTO_POR_UNA_CLAVE_LARGA_Y_ALEATORIA_EN_TU_ARCHIVO_ENV
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15

# --- CORS ---
# Qué orígenes (dominios) pueden hacer peticiones a nuestra API.
# Durante el desarrollo, Angular corre en localhost:4200.
# Múltiples orígenes separados por coma.
ALLOWED_ORIGINS=["http://localhost:4200","http://localhost:3000"]
